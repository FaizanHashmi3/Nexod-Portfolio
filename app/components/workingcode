"use client";

import { useEffect, useRef } from "react";
import gsap, { ScrollTrigger } from "../../lib/gsap";

export default function StoryCanvas() {

    const canvasRef = useRef<HTMLCanvasElement>(null);

    useEffect(() => {

        gsap.registerPlugin(ScrollTrigger);

        const canvas = canvasRef.current!;
        const ctx = canvas.getContext("2d")!;

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        resize();
        window.addEventListener("resize", resize);

        /* ========================= */
        /* GLOBAL SCROLL ENGINE */
        /* ========================= */

        let globalProgress = 0;

        ScrollTrigger.create({
            trigger: document.body,
            start: "top top",
            end: "bottom bottom",
            scrub: true,
            onUpdate: self => {
                globalProgress = self.progress;
            }
        });

        /* ========================= */
        /* SECTION MAPPING */
        /* ========================= */

        const ranges = {
            HERO: [0.0, 0.25],
            PROCESS: [0.25, 0.45],
            SERVICES: [0.45, 0.65],
            CTA: [0.65, 1.0]
        };

        function normalize(progress: number, start: number, end: number) {
            return Math.min(
                Math.max((progress - start) / (end - start), 0),
                1
            );
        }

        /* ========================= */
        /* DOTS */
        /* ========================= */

        interface Dot {
            x: number;
            y: number;
        }

        const dots: Dot[] = [
            { x: canvas.width * 0.75, y: canvas.height * 0.3 },
            { x: canvas.width * 0.75, y: canvas.height * 0.3 },
            { x: canvas.width * 0.75, y: canvas.height * 0.3 }
        ];

        const EMERGENCE_START = 0.15;
        const EMERGENCE_END = 0.30;
        const PARTICLE_COUNT = 90;

        const emergenceParticles = Array.from({ length: PARTICLE_COUNT }).map((_, i) => ({
            group: i % 3,
            seed: i
        }));
        /* ========================= */
        /* TARGET COMPUTATION */
        /* ========================= */

        function computeTargets() {

            const p = globalProgress;

            const keyframes = [
                // 0.00 — HERO SPHERE CENTER (dots hidden inside sphere)
                {
                    at: 0.0,
                    getLayout: () => dots.map(() => ({
                        x: canvas.width * 0.75,
                        y: canvas.height * 0.3
                    }))
                },

                // 0.15 — DOTS EMERGE AROUND SPHERE
                {
                    at: 0.15,
                    getLayout: () => {
                        const cx = canvas.width * 0.75;
                        const cy = canvas.height * 0.3;

                        return dots.map((_, i) => {
                            const angle = (i / 3) * Math.PI * 2;
                            return {
                                x: cx + Math.cos(angle) * 60,
                                y: cy + Math.sin(angle) * 60
                            };
                        });
                    }
                },

                // 0.30 — MERGE INTO PROCESS CENTER
                {
                    at: 0.30,
                    getLayout: () => dots.map(() => ({
                        x: canvas.width * 0.5,
                        y: canvas.height * 0.5
                    }))
                },

                // 0.55 — SERVICES SPREAD
                {
                    at: 0.55,
                    getLayout: () => dots.map((_, i) => ({
                        x: canvas.width * 0.4 + i * 120,
                        y: canvas.height * 0.6
                    }))
                },

                // 0.75 — CENTER CLUSTER (WHY / CLIENTS placeholder)
                {
                    at: 0.75,
                    getLayout: () => dots.map(() => ({
                        x: canvas.width * 0.5,
                        y: canvas.height * 0.5
                    }))
                },

                // 1.00 — CTA ORBIT
                {
                    at: 1.0,
                    getLayout: () => {
                        const centerX = canvas.width * 0.5;
                        const centerY = canvas.height * 0.5;

                        return dots.map((_, i) => {
                            const angle =
                                (globalProgress - 0.75) / (1 - 0.75) * Math.PI * 4 +
                                i * (Math.PI * 2 / dots.length);

                            const radius = 80 + i * 20;

                            return {
                                x: centerX + Math.cos(angle) * radius,
                                y: centerY + Math.sin(angle) * radius
                            };
                        });
                    }
                }
            ];

            // Find surrounding keyframes
            let k1 = keyframes[0];
            let k2 = keyframes[keyframes.length - 1];

            for (let i = 0; i < keyframes.length - 1; i++) {
                if (p >= keyframes[i].at && p <= keyframes[i + 1].at) {
                    k1 = keyframes[i];
                    k2 = keyframes[i + 1];
                    break;
                }
            }

            const span = k2.at - k1.at;
            const t = span === 0 ? 0 : (p - k1.at) / span;

            const layout1 = k1.getLayout();
            const layout2 = k2.getLayout();

            return layout1.map((pos1, i) => ({
                x: pos1.x + (layout2[i].x - pos1.x) * t,
                y: pos1.y + (layout2[i].y - pos1.y) * t
            }));
        }

        /* ========================= */
        /* RENDER LOOP */
        /* ========================= */

        let lastProgress = 0;

        function render() {

            ctx.clearRect(0, 0, canvas.width, canvas.height);

            const targets = computeTargets();

            const progressDelta = Math.abs(globalProgress - lastProgress);
            lastProgress = globalProgress;

            const sphereStart = 0.0;
            const sphereEnd = 0.20;

            if (globalProgress < sphereEnd) {

                const t = Math.min(globalProgress / 0.15, 1);

                const fadeT = Math.max(
                    1 - (globalProgress - 0.15) / 0.05,
                    0
                );

                const cx = canvas.width * 0.75;
                const cy = canvas.height * 0.3;

                const radius = 180;
                const points = 120;

                for (let i = 0; i < points; i++) {

                    const phi = Math.acos(-1 + (2 * i) / points);
                    const theta = Math.sqrt(points * Math.PI) * phi;

                    const angle = t * Math.PI * 4;

                    const x =
                        radius *
                        Math.cos(theta + angle) *
                        Math.sin(phi);

                    const y =
                        radius *
                        Math.sin(theta + angle) *
                        Math.sin(phi);

                    const z =
                        radius *
                        Math.cos(phi);

                    const scale =
                        900 / (900 - z);

                    ctx.beginPath();
                    ctx.arc(
                        cx + x * scale,
                        cy + y * scale,
                        2 * scale,
                        0,
                        Math.PI * 2
                    );

                    ctx.fillStyle =
                        `rgba(0,0,0,${(0.2 + scale * 0.5) * fadeT})`;

                    ctx.fill();
                }
            }

            if (globalProgress >= EMERGENCE_START && globalProgress <= EMERGENCE_END) {

                const t =
                    (globalProgress - EMERGENCE_START) /
                    (EMERGENCE_END - EMERGENCE_START);

                const cx = canvas.width * 0.75;
                const cy = canvas.height * 0.3;

                const processCenter = {
                    x: canvas.width * 0.5,
                    y: canvas.height * 0.5
                };

                emergenceParticles.forEach((p: any) => {

                    const angle = (p.seed / PARTICLE_COUNT) * Math.PI * 6;
                    const radius = 120;

                    const startX =
                        cx + Math.cos(angle) * radius;
                    const startY =
                        cy + Math.sin(angle) * radius;

                    const targetAngle =
                        (p.group / 3) * Math.PI * 2;

                    const targetX =
                        processCenter.x +
                        Math.cos(targetAngle) * 10;

                    const targetY =
                        processCenter.y +
                        Math.sin(targetAngle) * 10;

                    const x =
                        startX +
                        (targetX - startX) * t;

                    const y =
                        startY +
                        (targetY - startY) * t;

                    ctx.beginPath();
                    ctx.arc(x, y, 2, 0, Math.PI * 2);

                    ctx.fillStyle =
                        `rgba(0,0,0,${1 - t})`;

                    ctx.fill();
                });
            }

            dots.forEach((dot, i) => {

                const tx = targets[i].x;
                const ty = targets[i].y;

                dot.x = tx;
                dot.y = ty;

                ctx.beginPath();
                ctx.arc(dot.x, dot.y, 10, 0, Math.PI * 2);
                ctx.fillStyle = ["#22c55e", "#3b82f6", "#ef4444"][i];
                ctx.fill();
            });

            requestAnimationFrame(render);
        }

        render();

        return () => {
            ScrollTrigger.getAll().forEach(t => t.kill());
            window.removeEventListener("resize", resize);
        };

    }, []);

    return (
        <canvas
            ref= { canvasRef }
    style = {{
        position: "fixed",
            inset: 0,
                pointerEvents: "none",
                    zIndex: 30
    }
}
        />
    );
}