function AnimatedBullet({ color }: { color: string }) {
    const uid = color.replace("#", "");
    return (
        <svg xmlns="http://www.w3.org/2000/svg" width="46" height="46" viewBox="0 0 36 36" style={{ flexShrink: 0 }}>
            <style>{`
        @keyframes spin-ring-${uid}{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
        .ring-${uid}{transform-origin:18px 18px;animation:spin-ring-${uid} 2.8s linear infinite}
      `}</style>
            <circle className={`ring-${uid}`} cx="18" cy="18" r="18"
                fill="none" stroke="#000" strokeWidth="1.5" strokeDasharray="3.5 4.5" opacity="0.6" />
            <circle cx="18" cy="18" r="14" fill={color} />
        </svg>
    );
}

