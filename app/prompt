// ── Component ────────────────────────────────────────────────────────────────
export default function Services() {
    const sectionRef = useRef<HTMLElement>(null);
    const headingRef = useRef<HTMLDivElement>(null);
    const taglineRef = useRef<HTMLParagraphElement>(null);
    const cardsRef = useRef<(HTMLDivElement | null)[]>([]);
    const fillRefs = useRef<(HTMLDivElement | null)[]>([]);
    const contentRefs = useRef<(HTMLDivElement | null)[]>([]);
    const [hoveredIdx, setHoveredIdx] = useState<number | null>(null);

    useEffect(() => {
        const ctx = gsap.context(() => {

            // ── Heading lines reveal ──────────────────────────────────────────
            const headingLines = headingRef.current?.querySelectorAll<HTMLElement>(".line-wrap");
            if (headingLines && headingLines.length > 0) {
                gsap.fromTo(
                    headingLines,
                    { y: 80, opacity: 0, rotateX: -15 },
                    {
                        y: 0, opacity: 1, rotateX: 0,
                        duration: 1.1, ease: "power4.out", stagger: 0.12,
                        scrollTrigger: {
                            trigger: headingRef.current,
                            start: "top 80%",
                            toggleActions: "play none none reset",
                        },
                    }
                );
            }

            // ── Tagline reveal ────────────────────────────────────────────────
            if (taglineRef.current) {
                gsap.fromTo(
                    taglineRef.current,
                    { y: 30, opacity: 0 },
                    {
                        y: 0, opacity: 1, duration: 0.9, ease: "power3.out", delay: 0.4,
                        scrollTrigger: {
                            trigger: taglineRef.current,
                            start: "top 85%",
                            toggleActions: "play none none reset",
                        },
                    }
                );
            }

            // ── Cards ─────────────────────────────────────────────────────────
            cardsRef.current.forEach((card, i) => {
                if (!card) return;

                // No entry animation — cards visible immediately

                const fill = fillRefs.current[i];
                const content = contentRefs.current[i];
                if (!fill || !content) return;

                gsap.set(fill, { scaleY: 0, transformOrigin: "top center" });

                let isFilled = false;

                // ── ST1: card's top hits viewport bottom (scroll down = enter from below)
                //         card's top leaves viewport bottom (scroll up = exit below)
                ScrollTrigger.create({
                    trigger: card,
                    start: "top bottom",   // card 1% enters from bottom
                    onEnter: () => {
                        // scroll DOWN — fill top center → downward
                        if (isFilled) return;
                        isFilled = true;
                        gsap.set(fill, { transformOrigin: "top center", scaleY: 0 });
                        gsap.to(fill, { scaleY: 1, duration: 0.65, ease: "power2.inOut" });
                        gsap.to(content, { color: "#ffffff", duration: 0.35, delay: 0.25, ease: "power2.out" });
                    },
                    onLeaveBack: () => {
                        // scroll UP — card fully exits bottom → drain top center downward
                        isFilled = false;
                        gsap.set(fill, { transformOrigin: "top center", scaleY: 1 });
                        gsap.to(fill, { scaleY: 0, duration: 0.6, ease: "power2.inOut" });
                        gsap.to(content, { color: "#000000", duration: 0.3, ease: "power2.out" });
                    },
                });

                // ── ST2: card's bottom hits 20% from top (80% of card gone above)
                //         card's bottom leaves 20% mark going back down (scroll up)
                ScrollTrigger.create({
                    trigger: card,
                    start: CARD_DRAIN_TRIGGER,
                    onEnter: () => {
                        // scroll DOWN — drain bottom center → upward
                        isFilled = false;
                        gsap.set(fill, { transformOrigin: "bottom center", scaleY: 1 });
                        gsap.to(fill, { scaleY: 0, duration: 0.65, ease: "power2.inOut" });
                        gsap.to(content, { color: "#000000", duration: 0.35, ease: "power2.out" });
                    },
                    onLeaveBack: () => {
                        // scroll UP — card re-enters from top (20% visible) → fill bottom center upward
                        isFilled = true;
                        gsap.set(fill, { transformOrigin: "bottom center", scaleY: 0 });
                        gsap.to(fill, { scaleY: 1, duration: 0.65, ease: "power2.inOut" });
                        gsap.to(content, { color: "#ffffff", duration: 0.35, delay: 0.25, ease: "power2.out" });
                    },
                });
            });

        }, sectionRef);

        return () => ctx.revert();
    }, []);

