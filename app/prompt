// How much of the card must exit the top before draining (0–100).
// e.g. 80 = drain when 80% of card has scrolled above the viewport.
const CARD_DRAIN_EXIT_PERCENT = 50;
const CARD_DRAIN_TRIGGER = `bottom ${100 - CARD_DRAIN_EXIT_PERCENT}%`;

